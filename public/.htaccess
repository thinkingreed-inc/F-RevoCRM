# Allow access to public directory
allow from all

# Disable server signature in error pages (Apache version info leak prevention)
ServerSignature Off

# Security Headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    # Content Security Policy (CSP) - PHP側(Vtiger_Response::buildCSPHeader)で環境に応じて動的に設定
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block access to hidden files and directories (starting with .)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block access to .git directory and its contents
RedirectMatch 404 /\.git

# Block access to sensitive files
<FilesMatch "(^\.env|\.sql|\.bak|\.log|\.ini|\.sh)$">
    Require all denied
</FilesMatch>